# Вставь сюда authorization key из GigaChat Studio / кабинета разработчика
# Это НЕ access_token.
GIGACHAT_AUTH_KEY=MDE5Y2E4MGEtNDUwYy03NmRhLTg0ZTAtMTkzYzQyZjY4ODJjOmI0NDA2NTE4LWM2NDYtNDYzZi04OTRiLTlhMzZhZTczYWYxZA==

# Для физлиц обычно подходит этот scope.
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Модель по умолчанию.
GIGACHAT_MODEL=GigaChat-2-Max

PORT=3000

# Для локальной демонстрации, только если сертификаты ещё не установлены.
# Лучше сначала попробовать нормальную установку корневого сертификата.
GIGACHAT_TLS_SKIP_VERIFY=true
